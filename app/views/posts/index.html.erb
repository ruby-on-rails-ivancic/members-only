<h1>Posts</h1>

<% if @posts.any? %>
    <% @posts.each do |post| %>
        <h2><%= post.title %></h2>
        <p><%= post.body %></p>
        <% if user_signed_in? %>
            <p>Posted by <%= post.user.username %>
        <% end %>
    <% end %>
<% else %>
    <p>No posts yet...</p>
<% end %>
<% if user_signed_in? %>
    <%= button_to "new post", new_post_path, :method => :get  %>
<% end %>